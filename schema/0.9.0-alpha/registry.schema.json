{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry.schema.json",
  "title": "leptos_ui_kit registry root",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "compatibility",
    "items"
  ],
  "properties": {
    "$schema": {
      "const": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry.schema.json"
    },
    "schemaVersion": {
      "const": "0.9.0-alpha"
    },
    "name": {
      "const": "leptos-ui-kit"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leptos",
        "primitives",
        "identityAbi",
        "layerAbi",
        "portalAbi"
      ],
      "properties": {
        "leptos": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version"
          ],
          "properties": {
            "version": {
              "const": "0.9.0-alpha"
            }
          }
        },
        "primitives": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "package",
            "requirement",
            "version",
            "presenceAbi"
          ],
          "properties": {
            "package": {
              "const": "web_ui_primitives"
            },
            "requirement": {
              "const": ">=0.2.0,<0.3.0"
            },
            "version": {
              "const": "0.2.0"
            },
            "presenceAbi": {
              "const": 2
            }
          }
        },
        "identityAbi": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "providerType",
            "ownerScopedFallback"
          ],
          "properties": {
            "version": {
              "const": 1
            },
            "providerType": {
              "const": "KitIdProvider"
            },
            "ownerScopedFallback": {
              "const": true
            }
          }
        },
        "layerAbi": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "order"
          ],
          "properties": {
            "version": {
              "const": 1
            },
            "order": {
              "const": [
                "leptos-ui-kit.tokens",
                "leptos-ui-kit.themes",
                "leptos-ui-kit.components"
              ]
            }
          }
        },
        "portalAbi": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "mountType",
            "propsType",
            "bodyHost"
          ],
          "properties": {
            "version": {
              "const": 1
            },
          "mountType": {
            "const": "web_ui_primitives::leptos::PortalMount"
          },
          "propsType": {
            "const": "web_ui_primitives::leptos::PortalProps"
          },
          "bodyHost": {
              "const": true
            }
          }
        }
      }
    },
    "items": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
            "not": {
              "enum": [
                "abstract",
                "as",
                "async",
                "await",
                "become",
                "box",
                "break",
                "const",
                "continue",
                "crate",
                "do",
                "dyn",
                "else",
                "enum",
                "extern",
                "false",
                "final",
                "fn",
                "for",
                "gen",
                "if",
                "impl",
                "in",
                "let",
                "loop",
                "macro",
                "macro_rules",
                "match",
                "mod",
                "move",
                "mut",
                "override",
                "priv",
                "pub",
                "raw",
                "ref",
                "return",
                "safe",
                "self",
                "static",
                "struct",
                "super",
                "trait",
                "true",
                "try",
                "type",
                "typeof",
                "union",
                "unsafe",
                "unsized",
                "use",
                "virtual",
                "where",
                "while",
                "yield"
              ]
            }
          },
          "path": {
            "type": "string",
            "pattern": "^(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*\\.json$"
          }
        }
      }
    }
  }
}
