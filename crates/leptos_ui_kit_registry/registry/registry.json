{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "leptos-ui-kit",
  "compatibility": {
    "leptos": {
      "version": "0.9.0-alpha"
    },
    "primitives": {
      "package": "web_ui_primitives",
      "requirement": ">=0.2.0,<0.3.0",
      "version": "0.2.0",
      "presenceAbi": 2
    },
    "identityAbi": {
      "version": 1,
      "providerType": "KitIdProvider",
      "ownerScopedFallback": true
    },
    "layerAbi": {
      "version": 1,
      "order": [
        "leptos-ui-kit.tokens",
        "leptos-ui-kit.themes",
        "leptos-ui-kit.components"
      ]
    },
    "portalAbi": {
      "version": 1,
      "mountType": "web_ui_primitives::leptos::PortalMount",
      "propsType": "web_ui_primitives::leptos::PortalProps",
      "bodyHost": true
    }
  },
  "items": [
    {
      "name": "anchor",
      "path": "ui/anchor.json"
    },
    {
      "name": "avatar",
      "path": "ui/avatar.json"
    },
    {
      "name": "badge",
      "path": "ui/badge.json"
    },
    {
      "name": "button",
      "path": "ui/button.json"
    },
    {
      "name": "card",
      "path": "ui/card.json"
    },
    {
      "name": "collapsible",
      "path": "ui/collapsible.json"
    },
    {
      "name": "dialog",
      "path": "ui/dialog.json"
    },
    {
      "name": "field",
      "path": "ui/field.json"
    },
    {
      "name": "identity",
      "path": "ui/identity.json"
    },
    {
      "name": "menu",
      "path": "ui/menu.json"
    },
    {
      "name": "router-link",
      "path": "ui/router-link.json"
    },
    {
      "name": "spinner",
      "path": "ui/spinner.json"
    },
    {
      "name": "status",
      "path": "ui/status.json"
    },
    {
      "name": "tabs",
      "path": "ui/tabs.json"
    },
    {
      "name": "tokens",
      "path": "foundation/tokens.json"
    }
  ]
}
