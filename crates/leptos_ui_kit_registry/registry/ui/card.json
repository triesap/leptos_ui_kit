{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "card",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Card",
  "description": "A pure-CSS Leptos sectioning card primitive.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderModes": ["csr", "hydrate", "ssr"]
  },
  "accessibility": {
    "behaviors": [{ "name": "native-section-semantics", "required": true }],
    "notes": ["Provide a heading when the card represents a distinct document section."]
  },
  "files": [
    {
      "source": "ui/card.rs",
      "target": { "kind": "ui", "path": "card.rs", "exports": ["Card"] }
    }
  ],
  "styles": [
    {
      "source": "styles/card.css",
      "target": { "kind": "managed-css-block", "id": "card" }
    }
  ],
  "registryDependencies": ["tokens"],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": { "kind": "version", "version": "0.9.0-alpha" },
      "features": [],
      "required": true
    }
  ],
  "extra": {}
}
