{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "menu",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Menu",
  "description": "A primitive-backed Leptos menu component family.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "menu-button-semantics",
        "required": true
      },
      {
        "name": "escape-and-outside-dismissal",
        "required": true
      },
      {
        "name": "roving-tabindex",
        "required": true
      },
      {
        "name": "checked-item-state",
        "required": true
      },
      {
        "name": "typeahead",
        "required": true
      },
      {
        "name": "return-focus",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/menu/mod.rs",
      "target": {
