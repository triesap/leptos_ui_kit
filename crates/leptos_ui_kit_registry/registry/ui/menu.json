    {
      "source": "ui/menu/root.rs",
      "target": {
        "kind": "ui",
        "path": "menu/root.rs",
        "exports": []
      }
    },
    {
      "source": "ui/menu/trigger.rs",
      "target": {
        "kind": "ui",
        "path": "menu/trigger.rs",
        "exports": []
      }
    },
    {
      "source": "ui/menu/content.rs",
      "target": {
        "kind": "ui",
        "path": "menu/content.rs",
        "exports": []
      }
    },
    {
      "source": "ui/menu/item.rs",
      "target": {
        "kind": "ui",
        "path": "menu/item.rs",
        "exports": []
      }
    },
    {
      "source": "ui/menu/item_indicator.rs",
      "target": {
        "kind": "ui",
        "path": "menu/item_indicator.rs",
        "exports": []
      }
    }
  ],
  "styles": [
    {
      "source": "styles/menu.css",
      "target": {
        "kind": "managed-css-block",
        "id": "menu"
      }
    }
