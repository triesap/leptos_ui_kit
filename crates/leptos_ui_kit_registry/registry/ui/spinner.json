{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "spinner",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Spinner",
  "description": "A pure-CSS Leptos loading spinner primitive.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "status-role",
        "required": true
      },
      {
        "name": "hidden-loading-label",
        "required": true
      },
      {
        "name": "decorative-spinner-mark",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/spinner.rs",
      "target": {
        "kind": "ui",
        "path": "spinner.rs",
        "exports": [
          "Spinner"
        ]
      }
    }
  ],
  "styles": [
    {
      "source": "styles/spinner.css",
      "target": {
        "kind": "managed-css-block",
        "id": "spinner"
      }
    }
  ],
  "registryDependencies": [],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [
        "csr"
      ],
      "required": true
    },
    {
      "crate": "leptos_router",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [],
      "required": true
    }
  ],
  "extra": {}
}
