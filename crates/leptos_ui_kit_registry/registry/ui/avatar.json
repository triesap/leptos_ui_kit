{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "avatar",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Avatar",
  "description": "A pure-CSS Leptos image avatar primitive.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderModes": ["csr", "hydrate", "ssr"]
  },
  "accessibility": {
    "behaviors": [
      { "name": "native-image-semantics", "required": true },
      { "name": "alternative-text", "required": true }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/avatar.rs",
      "target": { "kind": "ui", "path": "avatar.rs", "exports": ["Avatar"] }
    }
  ],
  "styles": [
    {
      "source": "styles/avatar.css",
      "target": { "kind": "managed-css-block", "id": "avatar" }
    }
  ],
  "registryDependencies": ["tokens"],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": { "kind": "version", "version": "0.9.0-alpha" },
      "features": [],
      "required": true
    }
  ],
  "extra": {}
}
