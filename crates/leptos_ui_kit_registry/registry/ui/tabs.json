{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "tabs",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Tabs",
  "description": "A primitive-backed Leptos tabs component family.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "tablist-role",
        "required": true
      },
      {
        "name": "tab-trigger-state",
        "required": true
      },
      {
        "name": "tabpanel-linkage",
        "required": true
      },
      {
        "name": "roving-tabindex",
        "required": true
      },
      {
        "name": "keyboard-focus-policy",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/tabs/mod.rs",
      "target": {
        "kind": "ui",
        "path": "tabs/mod.rs",
        "exports": [
          "TabsActivation",
          "TabsDirection",
          "TabsList",
          "TabsLoop",
          "TabsOrientation",
          "TabsPanel",
          "TabsRoot",
          "TabsTrigger"
        ]
      }
    },
    {
      "source": "ui/tabs/root.rs",
      "target": {
        "kind": "ui",
        "path": "tabs/root.rs",
        "exports": []
      }
    },
    {
      "source": "ui/tabs/list.rs",
      "target": {
        "kind": "ui",
        "path": "tabs/list.rs",
        "exports": []
      }
    },
    {
      "source": "ui/tabs/trigger.rs",
      "target": {
        "kind": "ui",
        "path": "tabs/trigger.rs",
        "exports": []
      }
    },
    {
      "source": "ui/tabs/panel.rs",
      "target": {
        "kind": "ui",
        "path": "tabs/panel.rs",
        "exports": []
      }
    }
  ],
  "styles": [
    {
      "source": "styles/tabs.css",
      "target": {
        "kind": "managed-css-block",
        "id": "tabs"
      }
    }
  ],
  "registryDependencies": [],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [
        "csr"
      ],
      "required": true
    },
    {
      "crate": "web_ui_primitives",
      "source": {
        "kind": "git",
        "url": "https://github.com/triesap/web_ui_primitives",
        "rev": "4472c5bab985c2dc3333c31bbdf193b24d36a979"
      },
      "features": [
        "leptos"
      ],
      "required": true
    }
  ],
  "extra": {}
}
