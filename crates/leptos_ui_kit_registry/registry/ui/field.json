  "styles": [
    {
      "source": "styles/field.css",
      "target": {
        "kind": "managed-css-block",
        "id": "field"
      }
    }
  ],
  "registryDependencies": [],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [
        "csr"
      ],
      "required": true
