{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "field",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Field",
  "description": "A pure-CSS Leptos form field structure component family.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "label-control-association",
        "required": true
      },
      {
        "name": "message-id-association",
        "required": true
      },
      {
        "name": "required-indicator-hidden-from-screen-readers",
        "required": true
      },
      {
        "name": "field-required-state-propagation",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/field/mod.rs",
      "target": {
        "kind": "ui",
        "path": "field/mod.rs",
        "exports": [
          "FieldLabel",
          "FieldMessage",
          "FieldRequired",
          "FieldRoot",
          "FieldSlot",
          "FieldSurface",
          "NativeSelect",
          "SelectField",
          "SelectIcon",
          "TextArea",
          "TextAreaField",
          "TextField",
          "TextInput",
          "TextInputType"
        ]
      }
    },
    {
      "source": "ui/field/slot.rs",
      "target": {
        "kind": "ui",
        "path": "field/slot.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/root.rs",
      "target": {
        "kind": "ui",
        "path": "field/root.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/surface.rs",
      "target": {
        "kind": "ui",
        "path": "field/surface.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/label.rs",
      "target": {
        "kind": "ui",
        "path": "field/label.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/required.rs",
      "target": {
        "kind": "ui",
        "path": "field/required.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/message.rs",
      "target": {
        "kind": "ui",
        "path": "field/message.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/text_input.rs",
      "target": {
        "kind": "ui",
        "path": "field/text_input.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/text_area.rs",
      "target": {
        "kind": "ui",
        "path": "field/text_area.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/text_field.rs",
      "target": {
        "kind": "ui",
        "path": "field/text_field.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/text_area_field.rs",
      "target": {
        "kind": "ui",
        "path": "field/text_area_field.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/native_select.rs",
      "target": {
        "kind": "ui",
        "path": "field/native_select.rs",
        "exports": []
      }
    },
    {
      "source": "ui/field/select_field.rs",
      "target": {
        "kind": "ui",
        "path": "field/select_field.rs",
        "exports": []
      }
    }
