{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "skeleton",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Skeleton",
  "description": "A pure-CSS Leptos decorative loading placeholder.",
  "leptos": { "version": "0.9.0-alpha", "routerVersion": "0.9.0-alpha", "renderModes": ["csr", "hydrate", "ssr"] },
  "accessibility": {
    "behaviors": [{ "name": "decorative-hidden-state", "required": true }],
    "notes": ["Expose loading state on the owning region; the placeholder itself is hidden from assistive technology."]
  },
  "files": [{ "source": "ui/skeleton.rs", "target": { "kind": "ui", "path": "skeleton.rs", "exports": ["Skeleton"] } }],
  "styles": [{ "source": "styles/skeleton.css", "target": { "kind": "managed-css-block", "id": "skeleton" } }],
  "registryDependencies": ["tokens"],
  "cargoPlan": [{ "crate": "leptos", "source": { "kind": "version", "version": "0.9.0-alpha" }, "features": [], "required": true }],
  "extra": {}
}
