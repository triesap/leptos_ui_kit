{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "progress",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Progress",
  "description": "A pure-CSS Leptos native progress primitive.",
  "leptos": { "version": "0.9.0-alpha", "routerVersion": "0.9.0-alpha", "renderModes": ["csr", "hydrate", "ssr"] },
  "accessibility": {
    "behaviors": [{ "name": "native-progress-semantics", "required": true }],
    "notes": ["Provide an associated label when surrounding context does not name the progress task."]
  },
  "files": [{ "source": "ui/progress.rs", "target": { "kind": "ui", "path": "progress.rs", "exports": ["Progress"] } }],
  "styles": [{ "source": "styles/progress.css", "target": { "kind": "managed-css-block", "id": "progress" } }],
  "registryDependencies": ["tokens"],
  "cargoPlan": [{ "crate": "leptos", "source": { "kind": "version", "version": "0.9.0-alpha" }, "features": [], "required": true }],
  "extra": {}
}
