{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "alert",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Alert",
  "description": "A pure-CSS Leptos assertive alert primitive.",
  "leptos": { "version": "0.9.0-alpha", "routerVersion": "0.9.0-alpha", "renderModes": ["csr", "hydrate", "ssr"] },
  "accessibility": {
    "behaviors": [{ "name": "alert-live-region", "required": true }],
    "notes": ["Use Status for non-urgent dynamic messages."]
  },
  "files": [{ "source": "ui/alert.rs", "target": { "kind": "ui", "path": "alert.rs", "exports": ["Alert"] } }],
  "styles": [{ "source": "styles/alert.css", "target": { "kind": "managed-css-block", "id": "alert" } }],
  "registryDependencies": ["tokens"],
  "cargoPlan": [{ "crate": "leptos", "source": { "kind": "version", "version": "0.9.0-alpha" }, "features": [], "required": true }],
  "extra": {}
}
