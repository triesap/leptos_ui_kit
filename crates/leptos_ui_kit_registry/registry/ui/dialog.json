{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "dialog",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Dialog",
  "description": "A primitive-backed Leptos dialog component family.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderModes": [
      "csr",
      "hydrate",
      "ssr"
    ]
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "required-accessible-name",
        "required": true
      },
      {
        "name": "modal-focus-trap",
        "required": true
      },
      {
        "name": "escape-and-outside-dismissal",
        "required": true
      },
      {
        "name": "return-focus",
        "required": true
      },
      {
        "name": "presence-exit-state",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/dialog/mod.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/mod.rs",
        "exports": [
          "DialogClose",
          "DialogContent",
          "DialogContentRole",
          "DialogDescription",
          "DialogRoot",
          "DialogTitle",
          "DialogTrigger"
        ]
      }
    },
    {
      "source": "ui/dialog/root.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/root.rs",
        "exports": []
      }
    },
    {
      "source": "ui/dialog/trigger.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/trigger.rs",
        "exports": []
      }
    },
    {
      "source": "ui/dialog/content.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/content.rs",
        "exports": []
      }
    },
    {
      "source": "ui/dialog/title.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/title.rs",
        "exports": []
      }
    },
    {
      "source": "ui/dialog/description.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/description.rs",
        "exports": []
      }
    },
    {
      "source": "ui/dialog/close.rs",
      "target": {
        "kind": "ui",
        "path": "dialog/close.rs",
        "exports": []
      }
    }
  ],
  "styles": [
    {
      "source": "styles/dialog.css",
      "target": {
        "kind": "managed-css-block",
        "id": "dialog"
      }
    }
  ],
  "registryDependencies": [
    "tokens"
  ],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [],
      "required": true
    },
    {
      "crate": "web_ui_primitives",
      "source": {
        "kind": "git",
        "url": "https://github.com/triesap/web_ui_primitives",
        "rev": "a7ad19e203c08be19040154fa6bce909701d402f"
      },
      "features": [
        "leptos"
      ],
      "required": true
    }
  ],
  "extra": {}
}
