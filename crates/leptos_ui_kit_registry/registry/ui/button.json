{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "button",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Button",
  "description": "A pure-CSS Leptos button component.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderModes": [
      "csr",
      "hydrate",
      "ssr"
    ]
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "native-button-semantics",
        "required": true
      },
      {
        "name": "focus-visible-state",
        "required": true
      },
      {
        "name": "loading-busy-state",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/button.rs",
      "target": {
        "kind": "ui",
        "path": "button.rs",
        "exports": [
          "Button",
          "ButtonSize",
          "ButtonType",
          "ButtonVariant"
        ]
      }
    }
  ],
  "styles": [
    {
      "source": "styles/button.css",
      "target": {
        "kind": "managed-css-block",
        "id": "button"
      }
    }
  ],
  "registryDependencies": [
    "tokens",
    "spinner"
  ],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [],
      "required": true
    }
  ],
  "extra": {}
}
