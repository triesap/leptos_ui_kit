{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "name": "anchor",
  "kind": "ui",
  "version": "0.9.0-alpha",
  "title": "Anchor",
  "description": "A pure-CSS Leptos native anchor primitive.",
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "accessibility": {
    "behaviors": [
      {
        "name": "native-anchor-semantics",
        "required": true
      },
      {
        "name": "external-target-rel-safety",
        "required": true
      },
      {
        "name": "focus-visible-style",
        "required": true
      }
    ],
    "notes": []
  },
  "files": [
    {
      "source": "ui/anchor.rs",
      "target": {
        "kind": "ui",
        "path": "anchor.rs",
        "exports": [
          "Anchor",
          "AnchorTarget"
        ]
      }
    }
  ],
  "styles": [
    {
      "source": "styles/anchor.css",
      "target": {
        "kind": "managed-css-block",
        "id": "anchor"
      }
    }
  ],
  "registryDependencies": [],
  "cargoPlan": [
    {
      "crate": "leptos",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [
        "csr"
      ],
      "required": true
    },
    {
      "crate": "leptos_router",
      "source": {
        "kind": "version",
        "version": "0.9.0-alpha"
      },
      "features": [],
      "required": true
    }
  ],
  "extra": {}
}
