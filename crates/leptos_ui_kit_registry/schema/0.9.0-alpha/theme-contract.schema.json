{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/theme-contract.schema.json",
  "title": "leptos_ui_kit semantic theme contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "contractVersion",
    "name",
    "tokens"
  ],
  "properties": {
    "$schema": {
      "const": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/theme-contract.schema.json"
    },
    "schemaVersion": {
      "const": "0.9.0-alpha"
    },
    "contractVersion": {
      "const": "1"
    },
    "name": {
      "const": "leptos-ui-kit-semantic"
    },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "category",
          "required",
          "default",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^--kit-[a-z][a-z0-9-]*$"
          },
          "category": {
            "enum": [
              "color",
              "shape",
              "elevation",
              "motion",
              "state"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "default": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
