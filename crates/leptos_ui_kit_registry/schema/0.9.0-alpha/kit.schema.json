{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/kit.schema.json",
  "title": "leptos_ui_kit kit.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "tool",
    "project",
    "leptos",
    "install",
    "styles",
    "registry",
    "items"
  ],
  "properties": {
    "$schema": {
      "const": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/kit.schema.json"
    },
    "schemaVersion": {
      "const": "0.9.0-alpha"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "binary",
        "source"
      ],
      "properties": {
        "package": {
          "const": "leptos_ui_kit_cli"
        },
        "binary": {
          "const": "leptos_ui_kit"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "url",
            "rev"
          ],
          "properties": {
            "kind": {
              "const": "git"
            },
            "url": {
              "const": "https://github.com/triesap/leptos_ui_kit"
            },
            "rev": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            }
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "crateRoot",
        "srcDir"
      ],
      "properties": {
        "kind": {
          "enum": [
            "single-crate-trunk-csr",
            "single-crate-native-ssr",
            "single-crate-browser-hydration",
            "shared-library-crate"
          ]
        },
        "crateRoot": {
          "const": "."
        },
        "srcDir": {
          "const": "src"
        },
        "indexHtml": {
          "const": "index.html"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "single-crate-trunk-csr"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "indexHtml"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "single-crate-native-ssr",
                  "single-crate-browser-hydration",
                  "shared-library-crate"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "not": {
              "required": [
                "indexHtml"
              ]
            }
          }
        }
      ]
    },
    "leptos": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "routerVersion"
      ],
      "properties": {
        "version": {
          "const": "0.9.0-alpha"
        },
        "routerVersion": {
          "const": "0.9.0-alpha"
        },
        "renderMode": {
          "enum": [
            "csr",
            "hydrate",
            "ssr"
          ]
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uiDir",
        "uiMod",
        "componentsMod"
      ],
      "properties": {
        "uiDir": {
          "type": "string",
          "default": "src/components/ui",
          "pattern": "^src/(?:[A-Za-z_][A-Za-z0-9_]*/)+[A-Za-z_][A-Za-z0-9_]*$",
          "not": {
            "pattern": "(?:^|/)(?:Self|_kit|abstract|as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|gen|if|impl|in|let|loop|macro|macro_rules|match|mod|move|mut|override|priv|pub|raw|ref|return|safe|self|static|struct|super|trait|true|try|type|typeof|union|unsafe|unsized|use|virtual|where|while|yield)(?:/|$)"
          }
        },
        "uiMod": {
          "type": "string",
          "default": "src/components/ui/mod.rs",
          "pattern": "^src/(?:[A-Za-z_][A-Za-z0-9_]*/){2,}mod\\.rs$",
          "not": {
            "pattern": "(?:^|/)(?:Self|_kit|abstract|as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|gen|if|impl|in|let|loop|macro|macro_rules|match|mod|move|mut|override|priv|pub|raw|ref|return|safe|self|static|struct|super|trait|true|try|type|typeof|union|unsafe|unsized|use|virtual|where|while|yield)/"
          }
        },
        "componentsMod": {
          "type": "string",
          "default": "src/components/mod.rs",
          "pattern": "^src/(?:[A-Za-z_][A-Za-z0-9_]*/)+mod\\.rs$",
          "not": {
            "pattern": "(?:^|/)(?:Self|_kit|abstract|as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|gen|if|impl|in|let|loop|macro|macro_rules|match|mod|move|mut|override|priv|pub|raw|ref|return|safe|self|static|struct|super|trait|true|try|type|typeof|union|unsafe|unsized|use|virtual|where|while|yield)/"
          }
        }
      }
    },
    "styles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "css"
      ],
      "properties": {
        "mode": {
          "const": "pure-css"
        },
        "css": {
          "type": "string",
          "default": "styles/kit.css",
          "pattern": "^styles/(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*\\.css$"
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "const": "builtin"
        }
      }
    },
    "items": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "source"
        ],
        "properties": {
          "name": {
            "enum": [
              "anchor",
              "button",
              "collapsible",
              "dialog",
              "field",
              "identity",
              "menu",
              "router-link",
              "spinner",
              "status",
              "tabs",
              "tokens"
            ]
          },
          "source": {
            "const": "builtin"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "project": {
            "properties": {
              "kind": {
                "const": "single-crate-trunk-csr"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "leptos": {
            "required": [
              "renderMode"
            ],
            "properties": {
              "renderMode": {
                "const": "csr"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "properties": {
              "kind": {
                "const": "single-crate-native-ssr"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "leptos": {
            "required": [
              "renderMode"
            ],
            "properties": {
              "renderMode": {
                "const": "ssr"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "properties": {
              "kind": {
                "const": "single-crate-browser-hydration"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "leptos": {
            "required": [
              "renderMode"
            ],
            "properties": {
              "renderMode": {
                "const": "hydrate"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "properties": {
              "kind": {
                "const": "shared-library-crate"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "leptos": {
            "not": {
              "required": [
                "renderMode"
              ]
            }
          }
        }
      }
    }
  ]
}
