{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json",
  "title": "leptos_ui_kit registry item",
  "$defs": {
    "rust2024Keyword": {
      "enum": [
        "Self",
        "abstract",
        "as",
        "async",
        "await",
        "become",
        "box",
        "break",
        "const",
        "continue",
        "crate",
        "do",
        "dyn",
        "else",
        "enum",
        "extern",
        "false",
        "final",
        "fn",
        "for",
        "gen",
        "if",
        "impl",
        "in",
        "let",
        "loop",
        "macro",
        "macro_rules",
        "match",
        "mod",
        "move",
        "mut",
        "override",
        "priv",
        "pub",
        "raw",
        "ref",
        "return",
        "safe",
        "self",
        "static",
        "struct",
        "super",
        "trait",
        "true",
        "try",
        "type",
        "typeof",
        "union",
        "unsafe",
        "unsized",
        "use",
        "virtual",
        "where",
        "while",
        "yield"
      ]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "kind",
    "version",
    "title",
    "description",
    "leptos",
    "files",
    "styles",
    "cargoPlan"
  ],
  "properties": {
    "$schema": {
      "const": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/registry-item.schema.json"
    },
    "schemaVersion": {
      "const": "0.9.0-alpha"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "not": {
        "$ref": "#/$defs/rust2024Keyword"
      }
    },
    "kind": {
      "enum": [
        "ui",
        "foundation"
      ]
    },
    "version": {
      "const": "0.9.0-alpha"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "leptos": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "routerVersion"
      ],
      "properties": {
        "version": {
          "const": "0.9.0-alpha"
        },
        "routerVersion": {
          "const": "0.9.0-alpha"
        },
        "renderModes": {
          "type": "array",
          "prefixItems": [
            {
              "const": "csr"
            },
            {
              "const": "hydrate"
            },
            {
              "const": "ssr"
            }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "renderMode": {
          "const": "csr"
        }
      },
      "oneOf": [
        {
          "required": [
            "renderModes"
          ],
          "not": {
            "required": [
              "renderMode"
            ]
          }
        },
        {
          "required": [
            "renderMode"
          ],
          "not": {
            "required": [
              "renderModes"
            ]
          }
        }
      ]
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "behaviors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "required"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
              },
              "required": {
                "type": "boolean"
              }
            }
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "target"
        ],
        "properties": {
          "source": {
            "type": "string",
            "pattern": "^(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*\\.rs$"
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "path"
            ],
            "properties": {
              "kind": {
                "const": "ui"
              },
              "path": {
                "type": "string",
                "pattern": "^([a-z_][a-z0-9_]*\\.rs|[a-z_][a-z0-9_]*(/[a-z_][a-z0-9_]*)*/([a-z_][a-z0-9_]*|mod)\\.rs)$",
                "not": {
                  "anyOf": [
                    {
                      "pattern": "^mod\\.rs$"
                    },
                    {
                      "pattern": "(?:^|/)(?:abstract|as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|gen|if|impl|in|let|loop|macro|macro_rules|match|mod|move|mut|override|priv|pub|raw|ref|return|safe|self|static|struct|super|trait|true|try|type|typeof|union|unsafe|unsized|use|virtual|where|while|yield)/"
                    },
                    {
                      "pattern": "(?:^|/)(?:abstract|as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|gen|if|impl|in|let|loop|macro|macro_rules|match|move|mut|override|priv|pub|raw|ref|return|safe|self|static|struct|super|trait|true|try|type|typeof|union|unsafe|unsized|use|virtual|where|while|yield)\\.rs$"
                    }
                  ]
                }
              },
              "exports": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
                  "not": {
                    "$ref": "#/$defs/rust2024Keyword"
                  }
                },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    "styles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "target"
        ],
        "properties": {
          "source": {
            "type": "string",
            "pattern": "^(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*\\.css$"
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "id"
            ],
            "properties": {
              "kind": {
                "const": "managed-css-block"
              },
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
              }
            }
          }
        }
      }
    },
    "registryDependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
        "not": {
          "$ref": "#/$defs/rust2024Keyword"
        }
      }
    },
    "cargoPlan": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "crate",
          "source",
          "required"
        ],
        "properties": {
          "crate": {
            "enum": [
              "leptos",
              "leptos_router",
              "web_ui_primitives"
            ]
          },
          "source": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "version"
                ],
                "properties": {
                  "kind": {
                    "const": "version"
                  },
                  "version": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "url",
                  "rev"
                ],
                "properties": {
                  "kind": {
                    "const": "git"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "rev": {
                    "type": "string",
                    "pattern": "^[0-9a-fA-F]{40}$"
                  }
                }
              }
            ]
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_+./:-]+$"
            },
            "uniqueItems": true
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "extra": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "foundation"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "files": {
            "maxItems": 0
          },
          "styles": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "styles": {
            "maxItems": 1
          }
        }
      }
    }
  ]
}
