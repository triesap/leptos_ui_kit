{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.2.0/theme-integration.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "producer",
    "primitives",
    "contract",
    "stylesheet",
    "layerAbi",
    "portalAbi"
  ],
  "properties": {
    "$schema": { "const": "https://triesap.github.io/leptos_ui_kit/schema/0.2.0/theme-integration.schema.json" },
    "schemaVersion": { "const": "1.0.0" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "repository", "checksum"],
      "properties": {
        "package": { "const": "leptos_ui_kit_cli" },
        "version": { "type": "string", "minLength": 1 },
        "repository": { "const": "https://github.com/triesap/leptos_ui_kit" },
        "checksum": { "type": ["string", "null"] }
      }
    },
    "primitives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "requirement", "version", "checksum", "presenceAbi"],
      "properties": {
        "package": { "const": "web_ui_primitives" },
        "requirement": { "const": ">=0.2.0,<0.3.0" },
        "version": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "minLength": 1 },
        "presenceAbi": { "const": 2 }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "contractId",
        "abiVersion",
        "revision",
        "canonicalDigest",
        "installedBytesDigest"
      ],
      "properties": {
        "path": { "const": "token-contract.json" },
        "contractId": { "const": "leptos-ui-kit" },
        "abiVersion": { "const": 1 },
        "revision": { "type": "integer", "minimum": 1 },
        "canonicalDigest": { "$ref": "#/$defs/digest" },
        "installedBytesDigest": { "$ref": "#/$defs/digest" }
      }
    },
    "stylesheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "installedBytesDigest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "installedBytesDigest": { "$ref": "#/$defs/digest" }
      }
    },
    "layerAbi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "order"],
      "properties": {
        "version": { "const": 1 },
        "order": {
          "const": [
            "leptos-ui-kit.tokens",
            "leptos-ui-kit.themes",
            "leptos-ui-kit.components"
          ]
        }
      }
    },
    "portalAbi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "mountType", "bodyHost"],
      "properties": {
        "version": { "const": 1 },
        "mountType": { "const": "web_ui_primitives::leptos::PortalMount" },
        "bodyHost": { "const": true }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
