{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triesap.github.io/leptos_ui_kit/schema/0.2.0/token-contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "contractId",
    "abiVersion",
    "revision",
    "dtcgVersion",
    "dtcgProfile",
    "canonicalDigest",
    "tokens",
    "contrastChecks",
    "extensions"
  ],
  "properties": {
    "$schema": { "const": "https://triesap.github.io/leptos_ui_kit/schema/0.2.0/token-contract.schema.json" },
    "schemaVersion": { "const": "1.0.0" },
    "contractId": { "const": "leptos-ui-kit" },
    "abiVersion": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "dtcgVersion": { "const": "2025.10" },
    "dtcgProfile": { "const": "format+color+resolver:2025.10" },
    "canonicalDigest": { "$ref": "#/$defs/digest" },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/token" }
    },
    "contrastChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/contrast" }
    },
    "extensions": { "type": "object" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "type",
        "cssCustomProperty",
        "domain",
        "required",
        "order",
        "themeOverride",
        "default"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "color",
            "dimension",
            "duration",
            "number",
            "cubicBezier",
            "shadow",
            "fontFamily"
          ]
        },
        "cssCustomProperty": { "type": "string", "pattern": "^--kit-[a-z0-9-]+$" },
        "domain": {
          "enum": ["theme", "density", "motion", "contrast", "typography", "structural"]
        },
        "required": { "type": "boolean" },
        "order": { "type": "integer", "minimum": 1 },
        "themeOverride": { "type": "boolean" },
        "default": {}
      }
    },
    "contrast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "foreground", "background", "kind", "minimum"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "foreground": { "type": "string", "minLength": 1 },
        "background": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["text", "large-text", "non-text", "focus-indicator"] },
        "minimum": { "type": "number", "minimum": 1, "maximum": 21 }
      }
    }
  }
}
